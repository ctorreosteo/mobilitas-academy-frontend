# ================================================================
# Template variabili d'ambiente Mobilitas Academy
# Copia questo file in `.env` e compila i valori.
#
# IMPORTANTE: tutto ciò che inizia con `EXPO_PUBLIC_` finisce nel
# bundle JS pubblico dell'app ed è leggibile da chiunque scarichi
# l'IPA/APK. NON mettere qui veri segreti server-side: vanno tenuti
# su Firebase Functions o su un backend.
# ================================================================

# --- Backend / API (Mobilitas) ---------------------------------------
# In dev l'app usa il backend locale (default http://localhost:8080) salvo override sotto.
# Su dispositivo reale imposta EXPO_PUBLIC_API_LOCAL_IP (stesso IP mostrato da Expo, es. 192.168.1.54).
EXPO_PUBLIC_API_URL_LOCAL=http://localhost:8080
# true = in dev chiama comunque il backend di produzione
EXPO_PUBLIC_API_USE_PRODUCTION=false
EXPO_PUBLIC_API_LOCAL_IP=

# --- Firebase Functions ----------------------------------------------
# Se true, in dev usa comunque l'URL di produzione
EXPO_PUBLIC_FIREBASE_USE_PRODUCTION=true
# URL produzione delle Cloud Functions
EXPO_PUBLIC_FIREBASE_FUNCTIONS_URL=https://europe-west1-tuo-progetto.cloudfunctions.net
# URL locale (solo dev, su LAN). Lascia vuoto in produzione.
EXPO_PUBLIC_FIREBASE_FUNCTIONS_URL_LOCAL=
EXPO_PUBLIC_FIREBASE_LOCAL_IP=

# --- YouTube ---------------------------------------------------------
# API key pubblica (può finire nel bundle) - vincolala per package id su Google Cloud!
EXPO_PUBLIC_YOUTUBE_API_KEY=
# Client ID OAuth (pubblico - va nel bundle)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# ⚠️ Le seguenti chiavi SONO SEGRETE: non devono stare nel client.
# Lasciale vuote nel client e gestisci il refresh dal backend Firebase.
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=
EXPO_PUBLIC_YOUTUBE_REFRESH_TOKEN=
# Lista (csv) di playlist unlisted da mostrare
EXPO_PUBLIC_YOUTUBE_UNLISTED_PLAYLISTS=

# --- Cloudflare Stream -----------------------------------------------
EXPO_PUBLIC_CLOUDFLARE_ACCOUNT_ID=
# ⚠️ Token Cloudflare: NON metterlo nel client per produzione.
# Spostalo nel backend e firma gli URL lì.
EXPO_PUBLIC_CLOUDFLARE_STREAM_TOKEN=
EXPO_PUBLIC_CLOUDFLARE_STREAM_SUBDOMAIN=customer-xxxxxx.cloudflarestream.com
